{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
          "path": "/api/cron/sync-stays",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/sync-dining",
      "schedule": "30 2 * * 0"
    },
    {
      "path": "/api/cron/sync-activities",
      "schedule": "0 4 * * 1"
    },
    {
      "path": "/api/cron/health-check",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/cleanup",
      "schedule": "0 3 * * 6"
    }
  ]
}

